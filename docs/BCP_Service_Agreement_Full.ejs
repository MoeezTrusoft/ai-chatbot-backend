                    alt="Jerry Miller Signature" style="width: 40%" />
                  <% } else if (signature==="Robert Williams" ) { %>
                    <img
                      src="https://www.bookcraftpublishers.com/cdn-cgi/imagedelivery/tXX1eXFTW8RWMWWjsrsa2A/5a1fc027-4bed-4722-f7ab-420033007f00/Desktop960"
                      alt="Robert Williams Signature" style="width: 40%" />
                    <% } %>
