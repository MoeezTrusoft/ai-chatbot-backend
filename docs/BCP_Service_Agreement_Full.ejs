              The Client agrees to the following payment schedule:
            </div>

          </div>
          <% if (scheduleType==="100% upon signing" ) { %>
            <div class="list">
              <ul class="list-ul">
                <li>
                  100% of the total fee shall be paid upon signing this Agreement.
                </li>
              </ul>
            </div>
            <% } else if (scheduleType==="Percentage + Monthly Installments" ) { %>
              <div class="list">
                <ul class="list-ul">
                  <li>
                    <%= initialPercentage %>% shall be paid upon signing this Agreement.
                  </li>
                  <li>
                    The remaining <%= remainingPercentage %>% shall be paid in <%= numberOfMonths %> equal monthly
                        installments of USD <%= installmentAmount %> each.
                  </li>
                </ul>
              </div>
              <% } else if (scheduleType==="Fixed Amount + Monthly Installments" ) { %>
                <div class="list">
                  <ul class="list-ul">
                    <li>
                      An initial payment of USD <%= initialAmount %> shall be made upon signing this Agreement.
                    </li>
                    <li>
                      The remaining USD <%= remainingAmount %> shall be paid in <%= numberOfMonths %> equal monthly
                          installments of USD <%= installmentAmount %> each.
                    </li>
                  </ul>
                </div>
                <% } else if (scheduleType==="Advance + Final Payment (linked to service)" ) { %>
                  <div class="list">
                    <ul class="list-ul">
                      <li>
                        <%= advancePercentage %>% of the total fee shall be paid upon signing this Agreement.
                      </li>
                      <li>
                        The remaining <%= finalPercentage %>% shall be paid <%= beforeOrAfter ? 'before' : 'after' %>
                            completion of <%= finalMilestoneService %>.
                      </li>
                    </ul>
