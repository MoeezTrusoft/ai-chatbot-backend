                  <% } else if (scheduleType==="Milestone-Based Schedule" ) { %>
                    <div class="list">
                      <ul class="list-ul">
                        <% milestones.forEach(function(milestone) { %>
                          <li>
                            <%= milestone.percentage %>% shall be paid <%= milestone.beforeOrAfter %>
                                <%= milestone.description %>.
                          </li>
                          <% }); %>
                      </ul>
                    </div>
                    <% } %>
          <% } %>
