{
  "version": "query_intent_rules.v1",
  "rules": [
    {"id": "QI-GREETING-001", "layer": "exact", "target": {"query_intent": "greeting"}, "phrases": ["hello", "hi", "hey"], "confidence": 0.98, "shortcut_allowed": true},
    {"id": "QI-SERVICE-001", "layer": "exact", "target": {"query_intent": "service_question"}, "phrases": ["tell me about your services"], "confidence": 0.98, "shortcut_allowed": true},
    {"id": "QI-PRICE-001", "layer": "exact", "target": {"query_intent": "pricing_question"}, "phrases": ["pricing quote"], "confidence": 0.98, "shortcut_allowed": true},
    {"id": "QI-PRICE-002", "layer": "regex", "target": {"query_intent": "pricing_question"}, "regex": "\\b(price|cost|quote|pricing)\\b", "confidence": 0.97, "shortcut_allowed": true},
    {"id": "QI-PRICE-003", "layer": "pattern", "target": {"query_intent": "pricing_question"}, "pattern": ["how", "much"], "confidence": 0.97, "shortcut_allowed": true},
    {"id": "QI-TIMELINE-001", "layer": "exact", "target": {"query_intent": "timeline_question"}, "phrases": ["timeline estimate"], "confidence": 0.98, "shortcut_allowed": true},
    {"id": "QI-PORTFOLIO-001", "layer": "exact", "target": {"query_intent": "portfolio_request"}, "phrases": ["portfolio samples"], "confidence": 0.98, "shortcut_allowed": true},
    {"id": "QI-CONSULT-001", "layer": "exact", "target": {"query_intent": "consultation_request"}, "phrases": ["book a consultation"], "confidence": 0.98, "shortcut_allowed": true},
    {"id": "QI-NDA-001", "layer": "exact", "target": {"query_intent": "nda_request"}, "phrases": ["send an nda"], "confidence": 0.98, "shortcut_allowed": true},
    {"id": "QI-AGREEMENT-001", "layer": "exact", "target": {"query_intent": "agreement_request"}, "phrases": ["service agreement"], "confidence": 0.98, "shortcut_allowed": true},
    {"id": "QI-REVISION-001", "layer": "exact", "target": {"query_intent": "revision_question"}, "phrases": ["revision policy"], "confidence": 0.96, "shortcut_allowed": true},
    {"id": "QI-PAYMENT-001", "layer": "exact", "target": {"query_intent": "payment_question"}, "phrases": ["payment options"], "confidence": 0.96, "shortcut_allowed": true},
    {"id": "QI-PLATFORM-001", "layer": "exact", "target": {"query_intent": "publishing_platform_question"}, "phrases": ["publishing platforms"], "confidence": 0.96, "shortcut_allowed": true},
    {"id": "QI-MS-001", "layer": "exact", "target": {"query_intent": "manuscript_status_update"}, "phrases": ["my manuscript is finished"], "confidence": 0.96, "shortcut_allowed": true},
    {"id": "QI-CONTACT-001", "layer": "exact", "target": {"query_intent": "contact_info_provided"}, "phrases": ["my email is"], "confidence": 0.96, "shortcut_allowed": true},
    {"id": "QI-COMPLAINT-001", "layer": "exact", "target": {"query_intent": "complaint_or_objection"}, "phrases": ["that is too expensive"], "confidence": 0.94, "shortcut_allowed": false},
    {"id": "QI-READY-001", "layer": "exact", "target": {"query_intent": "ready_to_buy"}, "phrases": ["ready to start"], "confidence": 0.96, "shortcut_allowed": true},
    {"id": "QI-UNCLEAR-001", "layer": "exact", "target": {"query_intent": "unclear"}, "phrases": ["not sure yet"], "confidence": 0.90, "shortcut_allowed": false},
    {"id": "QI-SPAM-001", "layer": "exact", "target": {"query_intent": "spam_or_abuse"}, "phrases": ["buy followers now"], "confidence": 0.98, "shortcut_allowed": false},
    {"id": "QI-OFFTOPIC-001", "layer": "exact", "target": {"query_intent": "off_topic"}, "phrases": ["what is the weather"], "confidence": 0.94, "shortcut_allowed": false},
    {"id": "QI-SEM-001", "layer": "semantic", "target": {"query_intent": "service_question"}, "semantic_examples": ["I want to understand BookCraft services"], "confidence": 0.70}
  ]
}
