# BookCraft Chatbot - Staging Environment Example
# Copy to your real staging secret store or .env.staging.local.
# Do NOT commit real secrets.

# -----------------------------------------------------------------------------
# App
# -----------------------------------------------------------------------------
APP_ENV=staging
APP_NAME=bookcraft-chatbot
APP_HOST=0.0.0.0
APP_PORT=8000
READINESS_CHECK_EXTERNALS=true
LANGUAGE_GUARD_ENABLED=true
LOG_LEVEL=INFO
LOG_FORMAT=json

# -----------------------------------------------------------------------------
# Database / Redis
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql+asyncpg://<user>:<password>@<postgres-host>:5432/<database>
DATABASE_REPLICA_URL=
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10

REDIS_URL=redis://<redis-host>:6379/0
REDIS_HOT_TTL_HOURS=24
REDIS_IDEMPOTENCY_TTL_HOURS=24
REDIS_RELATION_CACHE_TTL_HOURS=24

# -----------------------------------------------------------------------------
# RAG / Elasticsearch / TEI
# -----------------------------------------------------------------------------
ELASTICSEARCH_URL=http://<elasticsearch-host>:9200
ELASTICSEARCH_USER=
ELASTICSEARCH_PASSWORD=
ELASTICSEARCH_INDEX_PREFIX=bookcraft_

TEI_URL=http://<tei-host>:8080
TEI_TIMEOUT_SECONDS=10
TEI_DEGRADED_MODE_ENABLED=false
EMBEDDING_DIMENSIONS=384

RAG_INDEX_ALIAS=bookcraft_rag_current
RAG_INDEX_VERSION=bookcraft_rag_v1
RAG_SOURCE_DIR=data/rag-corpus/source_markdown
RAG_BUILD_DIR=data/rag-corpus/build
RAG_STRICT_VERIFIER=true
RAG_TOP_K=8

# -----------------------------------------------------------------------------
# LLM Mode
# -----------------------------------------------------------------------------
# Use mock for bootstrapping. Switch to live only after live-mode readiness passes.
LLM_PROVIDER_MODE=mock

ANTHROPIC_API_KEY=<set-in-secret-manager>
ANTHROPIC_BASE_URL=https://api.anthropic.com
ANTHROPIC_HAIKU_MODEL=claude-haiku-4-5
ANTHROPIC_SONNET_MODEL=claude-sonnet-4-5

OPENAI_API_KEY=<set-in-secret-manager>
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_INTENT_MODEL=gpt-5.4-mini

DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=http://deepseek-internal:8000/v1
DEEPSEEK_INTENT_MODEL=deepseek-chat

LLM_REQUEST_TIMEOUT_SECONDS=8
INTENT_ENSEMBLE_TIMEOUT_SECONDS=2.5
DEEPSEEK_TIMEOUT_SECONDS=4

# -----------------------------------------------------------------------------
# Auth / Security / Rate Limit
# -----------------------------------------------------------------------------
API_AUTH_MODE=jwt
JWT_SIGNING_KEY=<set-in-secret-manager>
JWT_TTL_HOURS=24
WS_ALLOWED_ORIGINS=https://<staging-frontend-domain>
RATE_LIMIT_PER_IP_PER_MINUTE=30

METRICS_PUBLIC=false
METRICS_BEARER_TOKEN=<set-in-secret-manager-if-metrics-public>

# -----------------------------------------------------------------------------
# Documents / Legal Safety
# -----------------------------------------------------------------------------
NDA_MODE=manual
AGREEMENT_MODE=manual
NDA_TEMPLATE_VERSION=v1.0
AGREEMENT_TEMPLATE_VERSION=v1.0
DOCUMENT_TEMPLATE_DIR=data/templates
DOCUMENT_OUTPUT_DIR=data/generated/documents
DOCUMENT_PDF_RENDERING_ENABLED=false
DOCUMENT_RETRACTION_HOURS=24
S3_DOCUMENTS_BUCKET=<staging-documents-bucket>
S3_REGION=us-east-1
DOCUMENT_SIGNED_URL_TTL_HOURS=24

# -----------------------------------------------------------------------------
# Email
# -----------------------------------------------------------------------------
EMAIL_PROVIDER=sendgrid
SENDGRID_API_KEY=<set-in-secret-manager-only-when-email-enabled>
EMAIL_FROM_ADDRESS=hello@bookcraft.ai
EMAIL_FROM_NAME=BookCraft AI

# -----------------------------------------------------------------------------
# Tri-Match / Funnel / Preprocessor
# -----------------------------------------------------------------------------
TRIMATCH_MODE=shadow
TRIMATCH_SHORTCUT_LAYERS=
TRIMATCH_SHORTCUT_THRESHOLD=0.95
TRIMATCH_AUTOCORRECT_ENABLED=false
TRIMATCH_AUTOAPPROVE_ENABLED=false
TRIMATCH_RULE_DIR=data/trimatch/rules
TRIMATCH_EVAL_DIR=data/trimatch/eval
TRIMATCH_FUNNEL_STAGE_WEIGHT=0.0
TRIMATCH_FUZZY_ENABLED=false
TRIMATCH_EXTRA_MODE=off
TRIMATCH_EXTRA_RULE_DIR=data/trimatch/reinforcement/staged_from_reviews
TRIMATCH_EXTRA_FUZZY_ENABLED=false

FUNNEL_SIGNAL_MODE=shadow
FUNNEL_RULE_SOURCE_PATH=data/funnel/funnel_stage_intents.sample.json
FUNNEL_RULE_BUILD_DIR=data/funnel/build
PREPROCESSOR_SIDECAR_DIR=data/trimatch/sidecars

# -----------------------------------------------------------------------------
# Pricing / Portfolio
# -----------------------------------------------------------------------------
PRICING_ENGINE_VERSION=v2
PRICING_V2_CONFIG_DIR=data/pricing/v2
PRICING_V2_VALUES_APPROVED=false
PRICING_STRICT_VERIFIER=true
PRICING_ALLOW_PLACEHOLDER_RULES=false
PRICING_QUOTE_VALID_DAYS=14

PORTFOLIO_SAMPLES_REGISTRY_PATH=data/portfolio/samples.registry.js
PORTFOLIO_GENRE_HIERARCHY_PATH=data/portfolio/genre_hierarchy_links.json
PORTFOLIO_SAMPLES_DOCX_PATH=data/portfolio/portfolio_samples.docx

# -----------------------------------------------------------------------------
# TRG
# -----------------------------------------------------------------------------
TRG_HOT_NODES_LIMIT=24
TRG_COMPACT_KEEP=12
TRG_RELATION_FAST_PATH_THRESHOLD=0.85
TRG_COMPLIANCE_THRESHOLD_DEFAULT=0.62

# -----------------------------------------------------------------------------
# Observability
# -----------------------------------------------------------------------------
OTEL_EXPORTER_OTLP_ENDPOINT=http://<otel-collector-host>:4317
SENTRY_DSN=
SENTRY_ENVIRONMENT=staging
